{
  "name": "zoom-bot-discord",
  "version": "3.0.0",
  "description": "Bot Discord ultime - Combine OSINT, gestion de serveur et système de niveaux",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "setup": "npm install @discordjs/opus@0.9.0 @discordjs/voice@0.16.1 --legacy-peer-deps",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop zoom-bot",
    "pm2:restart": "pm2 restart zoom-bot",
    "pm2:delete": "pm2 delete zoom-bot",
    "pm2:logs": "pm2 logs zoom-bot --lines 100",
    "pm2:monitor": "pm2 monit",
    "pm2:save": "pm2 save",
    "pm2:startup": "pm2 startup",
    "postinstall": "node scripts/patch-deps.js"
  },
  "keywords": [
    "discord",
    "bot",
    "osint",
    "intel-x",
    "snusbase",
    "nazapi",
    "levels",
    "moderation",
    "management"
  ],
  "author": "Zoom",
  "license": "MIT",
  "dependencies": {
    "@discordjs/opus": "^0.9.0",
    "@discordjs/voice": "^0.19.0",
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.6.2",
    "discord-html-transcripts": "^3.2.0",
    "discord.js": "14.14.1",
    "lyrics-finder": "^21.7.0",
    "mathjs": "^15.1.0",
    "moment": "^2.30.1",
    "mongoose": "^7.8.7",
    "ms": "^2.1.3",
    "pino": "^8.21.0",
    "play-dl": "^1.9.7",
    "qrcode": "^1.5.4",
    "quick.db": "^9.1.7",
    "whois-json": "^2.0.4",
    "yt-search": "^2.13.1"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/generator": "^7.28.5",
    "@babel/parser": "^7.28.5",
    "fast-glob": "^3.3.3",
    "nodemon": "^3.0.2",
    "pino-pretty": "^13.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
